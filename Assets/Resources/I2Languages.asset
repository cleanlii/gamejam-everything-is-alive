      Flags: 000000
      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u592A\u7A7A\u5750\u9A91_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u80FD\u4F53\u9A8C\u5728\u592A\u7A7A\u4E2D\u5931\u91CD\u611F\u7684\u795E\u5947\u6728\u9A6C\u6905\u3002"
      - "\u5EA7\u308B\u3068\u5B87\u5B99\u306B\u6D6E\u304B\u3079\u308B\u3088\u3046\u306A\u611F\u899A\u304C\u3059\u308B\u6728\u99AC\u6905\u5B50\u3002"
      - Magical rocking chair that lets you experience weightlessness in space.
