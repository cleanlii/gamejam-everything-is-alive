      Flags: 000000
      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u822A\u6D77\u65E5\u5FD7\u8155\u8868_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u5728\u4E00\u671B\u65E0\u57A0\u7684\u5927\u6D77\u4E2D\u4E5F\u53EF\u4E0D\u901A\u8FC7\u7F51\u7EDC\u8FDB\u884C\u7CBE\u786E\u5B9A\u4F4D\u3002"
      - "\u30CD\u30C3\u30C8\u306B\u7E4B\u304C\u3089\u306A\u304F\u3066\u3082\u4F4D\u7F6E\u60C5\u5831\u304C\u5206\u304B\u308BGPS\u30A6\u30A9\u30C3\u30C1\u3001\u822A\u6D77\u58EB\u306E\u5FC5\u9700\u54C1\u3067\u3042\u308B\u3002"
      - Precise positioning without network in the vast sea.
      Flags: 000000
      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u5149\u5B66\u7535\u6E90_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u611F\u5149\u81EA\u52A8\u6062\u590D\u80FD\u91CF\u7684\u5145\u7535\u5B9D\uFF0C\u5373\u4FBF\u5728\u591C\u665A\u7684\u706F\u5149\u4E0B\u3002"
      - "\u5149\u3092\u611F\u77E5\u3059\u308B\u3068\u30C1\u30E3\u30FC\u30B8\u3067\u304D\u308B\u30E2\u30D0\u30A4\u30EB\u30D0\u30C3\u30C6\u30EA\u30FC\u3001\u591C\u306E\u30E9\u30A4\u30C8\u30A2\u30C3\u30D7\u3082\u5BFE\u5FDC\u53EF\u80FD\u3002"
