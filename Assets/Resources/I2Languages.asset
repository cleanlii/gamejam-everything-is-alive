    - Term: "ItemDescription/Level_Text_Item_\u70AD\u70E4\u9F99\u867E_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u7528\u70AD\u706B\u6162\u70E4\u7684\u9F99\u867E\uFF0C\u9501\u4F4F\u6D77\u9C9C\u7684\u9C9C\u7F8E\uFF0C\u8089\u8D28\u7D27\u81F4\u591A\u6C41\u3002"
