      Flags: 000000
      Languages_Touch: []
    - Term: "RelicDescription/Level_Text_Relic_\u7E41\u8363\u5723\u50CF_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u4EE3\u8868\u7E41\u8363\u4E0E\u8D22\u5BCC\u7684\u5723\u50CF\uFF0C\u80FD\u63D0\u5347\u6240\u6709\u8D27\u7269\u7684\u57FA\u7840\u4EF7\u503C\u3002"
      - "\u7E41\u6804\u3068\u5BCC\u3092\u8C61\u5FB4\u3059\u308B\u8056\u50CF\u3067\u3001\u3059\u3079\u3066\u306E\u8CA8\u7269\u306E\u57FA\u672C\u4FA1\u5024\u3092\u9AD8\u3081\u308B\u3002"
