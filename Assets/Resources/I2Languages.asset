      Languages:
      - "\u53E4\u8001\u5DE8\u5CA9\u7684\u529B\u91CF\u52A0\u6301\uFF0C\u5956\u52B1\u7A33\u91CD\u800C\u5F3A\u5927\u7684\u8FD0\u8F93\u8005\u3002"
      - "\u53E4\u4EE3\u306E\u5DE8\u5CA9\u306E\u529B\u3092\u52A0\u3048\u305F\u3082\u306E\u3067\u3001\u5B89\u5B9A\u3057\u3066\u5F37\u529B\u306A\u8F38\u9001\u8005\u306B\u5831\u916C\u3092\u4E0E\u3048\u308B\u3002"
