      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u70E4\u867E\u4E32_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u7CBE\u9009\u65B0\u9C9C\u5927\u867E\uFF0C\u642D\u914D\u72EC\u7279\u814C\u6599\u70E4\u5236\uFF0C\u5916\u9999\u5185\u5AE9\uFF0C\u6563\u53D1\u8BF1\u4EBA\u9999\u6C14\u3002"
