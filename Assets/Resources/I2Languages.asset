    - Term: "Level_Text_Buff_1x2\u53CC\u80FD\u91CF_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u53CC\u6838\u5FC3\u7684\u9AD8\u7EA7\u80FD\u91CF\u88C5\u7F6E,\u8574\u542B\u7740\u53CC\u500D\u7684\u5F3A\u5927\u80FD\u91CF\u3002"
      - "\u4E8C\u91CD\u30B3\u30A2\u306E\u9AD8\u5EA6\u306A\u30A8\u30CD\u30EB\u30AE\u30FC\u88C5\u7F6E\u3067\u3001\u901A\u5E38\u306E2\u500D\u306E\u5F37\u529B\u306A\u30A8\u30CD\u30EB\u30AE\u30FC\u3092\u5185\u8535\u3057\u3066\u3044\u307E\u3059\u3002"
