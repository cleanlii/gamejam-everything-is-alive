    - Term: "UI_PopupWindow/PopupWindow_Text_\u4E8B\u4EF6\u70B9\u6E05\u96F6_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u5DF2\u7ECF\u6CA1\u6709\u5176\u4ED6\u53EF\u4EE5\u524D\u5F80\u7684\u8BA2\u5355\u4F4D\u7F6E\u4E86\uFF01\n\u51C6\u5907\u5F00\u59CB\u9001\u8D27\u5427\uFF01"
      - "\u4ED6\u306B\u5411\u304B\u3048\u308B\u6CE8\u6587\u306E\u5834\u6240\u304C\u3042\u308A\u307E\u305B\u3093\uFF01\n\u914D\u9054\u3092\u59CB\u3081\u307E\u3057\u3087\u3046\uFF01"
      - "There are no more order locations to go to! \nGet ready to start delivering!"
      Flags: 000000
      Languages_Touch: []
