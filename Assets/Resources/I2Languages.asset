      - "\u5305\u542B\u4E2A\u4EBA\u8EAB\u4EFD\u8BC1\u4EF6\u7684\u7EC8\u7AEF\uFF0C\u5728\u5C9B\u4E0A\u751F\u6D3B\u53EA\u9700\u8981\u62E5\u6709\u5B83\u5C31\u8DB3\u591F\u4E86\u3002"
      - "ID\u3092\u8A8D\u8A3C\u3067\u304D\u308B\u30C7\u30D0\u30A4\u30B9\u3001\u30B5\u30D7\u30EC\u30A2\u30B9\u4F4F\u6C11\u306F\u808C\u8EAB\u96E2\u3055\u305A\u6301\u3061\u6B69\u304F\u5FC5\u9808\u30A2\u30A4\u30C6\u30E0\u3002"
