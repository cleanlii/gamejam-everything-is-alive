    - Term: "Level_Text_Item_\u4E91\u6735\u7F8A\u808B\u6392_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u4EA7\u81EA\u5E7B\u4E91\u7267\u573A\u7684\u5F69\u4E91\u7F8A\uFF0C\u8089\u8D28\u8F7B\u76C8\u5982\u4E91\uFF0C\u5165\u53E3\u5373\u5316\u3002"
      - "\u5E7B\u96F2\u7267\u5834\u3067\u80B2\u3063\u305F\u5F69\u96F2\u7F8A\u3001\u8089\u8CEA\u304C\u96F2\u306E\u3088\u3046\u306A\u67D4\u3089\u304B\u3055\u3002"
      - Rainbow Sheep from Phantom Cloud Ranch, with meat as light as clouds, melting
        in the mouth.
      Flags: 000000
      Languages_Touch: []
