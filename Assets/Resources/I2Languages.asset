    - Term: "Level_Alert_5\u56DE\u5408_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u611F\u8C22\u60A8\u7684\u4F53\u9A8C\uFF01\n\u60A8\u5DF2\u7ECF\u5B8C\u6210\u4E86\u8BD5\u8FD0\u8425\uFF01\n\u662F\u5426\u8981\u7EE7\u7EED\u6E38\u73A95\u5929\u7684\u52A0\u73ED\u65E5\uFF1F"
      - "\u4F53\u9A13\u3044\u305F\u3060\u304D\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3059\uFF01\n\u8A66\u904B\u8EE2\u304C\u7D42\u4E86\u3057\u307E\u3057\u305F\uFF01\n\u6B8B\u696D\u65E5\u306E5\u65E5\u9593\u3092\u7D9A\u3051\u3066\u30D7\u30EC\u30A4\u3057\u307E\u3059\u304B\uFF1F"
      - 'Thank you for your play!

        You have completed the trial!

        Would
        you like to continue for the rest?'
      Flags: 000000
      Languages_Touch: []
    - Term: "Level_Alert_10\u56DE\u5408_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u611F\u8C22\u60A8\u7684\u4F53\u9A8C\uFF01\n\u60A8\u5DF2\u7ECF\u901A\u5173\u4E86\u52A0\u73ED\u65E5\uFF01"
      - "\u4F53\u9A13\u3044\u305F\u3060\u304D\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3059\uFF01\n\u6B8B\u696D\u65E5\u3092\u30AF\u30EA\u30A2\u3057\u307E\u3057\u305F\uFF01"
