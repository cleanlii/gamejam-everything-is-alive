      Languages_Touch: []
    - Term: "RelicRichText/Level_Text_Relic_\u79E9\u5E8F\u4E4B\u5370_RichText"
      TermType: 0
      Description: 
      Languages:
      - "\u7D2F\u8BA1\u9001\u51FA<color=#800000>10</color>\u4EF6\u666E\u901ATAG\u7684\u8D27\u7269\u540E\uFF0C\u83B7\u5F97<color=#800000>10</color>\u91D1\u5E01\u3002"
