      Languages_Touch: []
    - Term: "RelicDescription/Level_Text_Relic_\u5947\u6570\u91D1\u5E01_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u4E00\u679A\u5E26\u6709\u5947\u6570\u7B26\u53F7\u7684\u91D1\u5E01\uFF0C\u5728\u5947\u6570\u56DE\u5408\u95EA\u8000\u5149\u8292\u3002"
      - "\u5947\u6570\u306E\u30B7\u30F3\u30DC\u30EB\u304C\u523B\u307E\u308C\u305F\u30B3\u30A4\u30F3\u3067\u3001\u5947\u6570\u30BF\u30FC\u30F3\u3067\u8F1D\u304D\u3092\u653E\u3064\u3002"
