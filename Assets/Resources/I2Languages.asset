      Flags: 000000
      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u68A6\u5E7B\u5EA6\u5047\u6905_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u7531\u68A6\u5883\u7F16\u7EC7\u7684\u5E03\u6599\u5236\u6210\uFF0C\u5750\u4E0A\u53BB\u4F1A\u611F\u53D7\u5230\u62C2\u9762\u800C\u6765\u7684\u6D77\u98CE\u3002"
      - "\u5922\u3067\u7E54\u3089\u308C\u305F\u5E03\u3067\u4F5C\u3089\u308C\u3066\u304A\u308A\u3001\u5EA7\u308B\u3068\u6D77\u98A8\u3068\u78EF\u306E\u9999\u308A\u3092\u611F\u3058\u3089\u308C\u308B\u3002"
      - Made from dream-woven fabric, sitting on it brings feelings of sea breeze
