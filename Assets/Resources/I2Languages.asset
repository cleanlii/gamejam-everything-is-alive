      Languages_Touch: []
    - Term: "ItemDescription/Level_Text_Item_\u8106\u9AA8\u5927\u6392_Description"
      TermType: 0
      Description: 
      Languages:
      - "\u7EB5\u4EAB\u9ED1\u7389\u732A\u5E26\u6765\u7684\u5F39\u7259\u53E3\u611F\u4E0E\u80A5\u7F8E\u6ECB\u5473\u7684\u76DB\u5BB4\u3002"
      - "\u30B3\u30EA\u30B3\u30EA\u306A\u98DF\u611F\u3068\u3068\u308D\u3051\u308B\u5473\u308F\u3044\u304C\u7D21\u3050\u9ED2\u7389\u30B7\u30F3\u30D5\u30A9\u30CB\u30FC\u3002"
