  titleFont: {fileID: 11400000, guid: b1d34f2446d54d5429ccffcf5dbe8b0d, type: 2}
  descriptionFont: {fileID: 11400000, guid: b1d34f2446d54d5429ccffcf5dbe8b0d, type: 2}
  hintFont: {fileID: 11400000, guid: b1d34f2446d54d5429ccffcf5dbe8b0d, type: 2}
  statusFont: {fileID: 11400000, guid: b1d34f2446d54d5429ccffcf5dbe8b0d, type: 2}
  pakFont: {fileID: 11400000, guid: 7192538b81bd94a88bb2deccd8c379d7, type: 2}
  titleColor: {r: 1, g: 1, b: 1, a: 1}
  descriptionColor: {r: 0.78431374, g: 0.78431374, b: 0.78431374, a: 0.78431374}
  hintColor: {r: 1, g: 1, b: 1, a: 1}
  spinnerColor: {r: 0.7075472, g: 0.5840602, b: 0.5840602, a: 1}
  statusColor: {r: 1, g: 0.4901961, b: 0.7843138, a: 1}
  pakColor: {r: 1, g: 0.49019608, b: 0.78431374, a: 1}
  titleObjText: "\u573A\u666F\u52A0\u8F7D\u4E2D\uFF5E"
  titleObjDescText: "\u6D4B\u8BD5\u7528DEMO"
  pakText: "\u70B9\u51FB<b><color=#FFFFFF>\u4EFB\u610F\u4F4D\u7F6E</color></b> \u5F00\u59CB\u7ECF\u8425\uFF01"
  canvasGroup: {fileID: 4930707704756606854}
  backgroundCanvasGroup: {fileID: 4583459681700962831}
  contentCanvasGroup: {fileID: 2311895587901604181}
  pakCanvasGroup: {fileID: 8325703658713880088}
  statusObj: {fileID: 8176122580530308403}
  titleObj: {fileID: 0}
  descriptionObj: {fileID: 0}
  progressBar: {fileID: 2212180415645620343}
  backgroundImage: {fileID: 21300000, guid: 2da2d65ba233d904cb3f2cb2aeae95b7, type: 3}
  spinnerParent: {fileID: 7074673918802107113}
  enableRandomHints: 1
  hintsText: {fileID: 335400767272571063}
  changeHintWithTimer: 1
  hintTimerValue: 6.5
  hintList:
  - "\u6BCF\u4E2A\u5C9B\u5C7F\u90FD\u6709\u5176\u72EC\u7279\u7684\u8D44\u6E90\u548C\u6311\u6218\uFF0C\u63A2\u7D22\u5E76\u53D1\u73B0\u6700\u4F73\u7269\u6D41\u8DEF\u5F84\u5427\uFF01"
  - "\u5408\u7406\u9009\u62E9\u4EBA\u5458\u548C\u4EA4\u901A\u5DE5\u5177\uFF0C\u786E\u4FDD\u8D27\u7269\u53CA\u65F6\u51C6\u786E\u5730\u9001\u8FBE\u76EE\u7684\u5730\u3002"
  - "\u6CE8\u610F\u5929\u6C14\u9884\u62A5\uFF01\u98CE\u66B4\u6216\u96E8\u96EA\u53EF\u80FD\u4F1A\u5F71\u54CD\u60A8\u7684\u7269\u6D41\u901F\u5EA6\u548C\u5B89\u5168\u3002"
  - "\u7279\u6B8A\u5EFA\u7B51\u5982\u8F66\u7AD9\u548C\u533B\u9662\u9644\u8FD1\u53EF\u80FD\u4F1A\u6709\u4EA4\u901A\u62E5\u5835\uFF0C\u63D0\u524D\u89C4\u5212\u907F\u514D\u5EF6\u8BEF\u3002"
  - "\u6D77\u6D0B\u548C\u6CB3\u6D41\u8FDE\u63A5\u7740\u5C9B\u5C7F\uFF0C\u5408\u7406\u5229\u7528\u8239\u8236\u548C\u6865\u6881\uFF0C\u8BA9\u5C9B\u5C7F\u4E4B\u95F4\u7684\u7269\u6D41\u7545\u901A\u65E0\u963B\u3002"
  - "\u4E0D\u540C\u5EFA\u7B51\u63D0\u4F9B\u4E0D\u540C\u8D44\u6E90\uFF0C\u5408\u7406\u5B89\u6392\u4EA7\u80FD\u548C\u5B58\u50A8\uFF0C\u786E\u4FDD\u7269\u6D41\u94FE\u7684\u7A33\u5B9A\u8FD0\u884C\u3002"
  - "\u5B8C\u6210\u4EFB\u52A1\u53EF\u4EE5\u89E3\u9501\u65B0\u5EFA\u7B51\u548C\u4EA4\u901A\u5DE5\u5177\uFF0C\u4E0D\u65AD\u63D0\u5347\u60A8\u7684\u7269\u6D41\u80FD\u529B\u3002"
  - "\u6BCF\u4E00\u5C40\u6E38\u620F\u90FD\u662F\u5168\u65B0\u7684\u5730\u56FE\uFF0C\u4EAB\u53D7\u4E0D\u65AD\u63A2\u7D22\u548C\u5B66\u4E60\u7684\u4E50\u8DA3\uFF01"
  - "\u89C4\u5212\u7269\u6D41\u65F6\uFF0C\u4E0D\u8981\u5FD8\u8BB0\u4FDD\u62A4\u73AF\u5883\uFF0C\u5408\u7406\u5229\u7528\u8D44\u6E90\uFF0C\u5171\u5EFA\u7EFF\u8272\u5BB6\u56ED\u3002"
  - "\u4E0E\u670B\u53CB\u5408\u4F5C\uFF0C\u5171\u540C\u89C4\u5212\u548C\u5EFA\u8BBE\uFF0C\u8BA9\u7269\u6D41\u7F51\u7EDC\u66F4\u52A0\u5B8C\u5584\u548C\u9AD8\u6548\u3002"
  - "\u6B23\u8D4F\u6E38\u620F\u4E2D\u7CBE\u7F8E\u7684\u50CF\u7D20\u827A\u672F\uFF0C\u611F\u53D7\u4E0D\u540C\u5C9B\u5C7F\u548C\u5EFA\u7B51\u7684\u72EC\u7279\u98CE\u683C\u3002"
  - "\u786E\u4FDD\u4EA4\u901A\u5DE5\u5177\u548C\u884C\u4EBA\u7684\u5B89\u5168\uFF0C\u5408\u7406\u89C4\u5212\u9053\u8DEF\uFF0C\u9884\u9632\u4E8B\u6545\u3002"
